{# == Node Type Name           : Dimension Advanced Deploy == #}
{# == Node Type Description    : This node creates dimension table, view and also override create sql for view with advanced deployment strategy == #}

{% set nsAllVariables = namespace(currentDatabaseSchema = "",
                        desiredDatabaseSchema = "") %}
{{ initializeAllVariables(nsAllVariables) }}

{% if desiredState %}

    {# Override CreateSQL for view #}
    {% if desiredState.node.materializationType == 'view' %}
        
        {% if desiredState.node.override.create.enabled and desiredState.node.override.create.script | trim != "" %}
	
            {% if currentState != undefined %}
                {% if currentState.node.materializationType != 'view' %}
                    {{ stage('Drop Current Table - ' + currentState.node.name) }}
                    DROP TABLE IF EXISTS {{ ref_no_link(currentState.node.location.name, currentState.node.name) }}
                {% endif %}
            {% endif %}

            {{ desiredState.node.override.create.script }}


        {% else %}

            {% if currentState != undefined %}		
                {% if currentState.node.materializationType != 'view' %}

                    {{ stage('Drop Current Table - ' + currentState.node.name, true, "sql", "drop") }}
                    DROP TABLE IF EXISTS {{ ref_no_link(currentState.node.location.name, currentState.node.name) }}

                {% elif  desiredState.node.name != currentState.node.name
                            or nsAllVariables.desiredDatabaseSchema != nsAllVariables.currentDatabaseSchema  %}

                    {{ stage('Drop Current View - ' + currentState.node.name, true, "sql", "drop") }}
                    DROP VIEW IF EXISTS {{ ref_no_link(currentState.node.location.name, currentState.node.name) }}                    
                {% endif %}
            {% endif %}

            {# CreateSQL for View #}
            {% if currentState == undefined or currentState != desiredState %}
                {{ stage('Create Dimension View - ' + desiredState.node.name, true, "sql", "create") }}

                CREATE OR REPLACE VIEW {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                (
                    {% for col in desiredState.columns %}
                        `{{ col.name }}`
                        {%- if col.description | length > 0 %} COMMENT `{{ col.description | escape }}` {% endif %}
                        {%- if not loop.last -%},{% endif %}
                    {% endfor %}
                )
                {%- if desiredState.node.description | length > 0 %} COMMENT = '{{ desiredState.node.description | escape }}' {% endif %}
                AS
                {% for source in desiredState.sources %}

                    SELECT {% if desiredState.config.selectDistinct %} DISTINCT {% endif %}

                    {% for col in source.columns %}
                        {% if col.isSurrogateKey or col.isSystemUpdateDate or col.isSystemCreateDate %}
                            NULL
                        {% else %}
                            {{ get_source_transform(col) }}
                        {% endif %}
                        AS `{{ col.name }}`
                        {%- if not loop.last -%}, {% endif %}
                    {% endfor %}
                    {{ source.join }}
                    {% if desiredState.config.groupByAll %} Group By All {% endif %}
                    {% if not loop.last %}                 
                        {% if desiredState.config.insertStrategy in ['UNION DISTINCT', 'UNION ALL'] %}
                            {{ desiredState.config.insertStrategy }}
                        {% else %}
                            UNION DISTINCT
                        {% endif %} 
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endif %}

    {% elif desiredState.node.materializationType == 'table' %}

        {% set nsCreateVariables = namespace(options = "", partionBy = "", clusterBy = "", primaryKey = "", tabEprnClause = "", createTable = false) %}

        {%- set nsCreateVariables.partionBy = getPartitionBy() | trim -%}
        {%- set nsCreateVariables.clusterBy = getClusterBy() | trim -%}
        {%- set nsCreateVariables.primaryKey = getPrimaryKey() | trim -%}
        {%- set nsCreateVariables.tabEprnClause = getTabExpirationClause() | trim -%}

        {% if currentState != undefined
                and (currentState.node.materializationType != desiredState.node.materializationType
                or desiredState.config.partitionBy != currentState.config.partitionBy
                or desiredState.config.get('partByColumnConfig', []) != currentState.config.get('partByColumnConfig', [])
                or desiredState.config.partByIngnTimeExpression != currentState.config.partByIngnTimeExpression
                or desiredState.config.partByColumn.name != currentState.config.partByColumn.name
                or desiredState.config.partBySqlExpression != currentState.config.partBySqlExpression
                or desiredState.config.clusterKey != currentState.config.clusterKey
                or desiredState.config.get('clusterKeyConfig', []) != currentState.config.get('clusterKeyConfig', [])
                or nsAllVariables.currentDatabaseSchema != nsAllVariables.desiredDatabaseSchema) %}
            {% set nsCreateVariables.createTable = true %}
        {% endif %}

        {# Alter table incase of any chnages in states #}
        {% if currentState != undefined
            and currentState.node.materializationType == desiredState.node.materializationType
            and createTable == false %}

            {# Rename / Move Object #}
            {% if currentState.node.name != desiredState.node.name %}

                {{ stage('Alter Table - Rename') }}
                ALTER TABLE  {{nsAllVariables.currentDatabaseSchema}}.{{currentState.node.name}}
                RENAME TO  {{ desiredState.node.name }}
        
            {% endif %}

            {% if (desiredState.config.primary
                    and currentState.config.primary == desiredState.config.primary
                    and currentState.config.get('primaryKeyConfig', []) != desiredState.config.get('primaryKeyConfig', []))
                    or (desiredState.config.primary and currentState.config.primary != desiredState.config.primary) %}
                {% if nsCreateVariables.primaryKey | length > 0 %}
                    {{ stage('Alter Table - Add Primary Key Constraint') }}
                    ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                    ADD PRIMARY KEY ( {{ nsCreateVariables.primaryKey}} ) NOT ENFORCED
                {% endif %}
            {% else %}
                {% if currentState.config.primary and desiredState.config.primary == false %}
                    {{ stage('Alter Table - Drop Primary Key Constraint') }}
                    ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                    DROP PRIMARY KEY
                {% endif %}
            {% endif %}

            {% set alterPartition = "" %}
            {% if desiredState.config.partitionFilter %}
                {% if desiredState.config.partitionFilter != currentState.config.partitionFilter %}
                    {% set alterPartition = 'require_partition_filter = TRUE' %}
                {% endif %}
            {% else %}
                {% if currentState.config.partitionFilter %}
                    {% set alterPartition = 'require_partition_filter = FALSE' %}
                {% endif %}
            {% endif %}

            {% if desiredState.config.partExpireDays | trim | length > 0 %}
                {% if desiredState.config.partExpireDays | trim  != currentState.config.partExpireDays | trim %}
                    {% if alterPartition | length > 0 %}
                        {% set alterPartition = alterPartition + ", " %}
                    {% endif %}
                    {% set alterPartition = alterPartition + 'partition_expiration_days = ' +  desiredState.config.partExpireDays %}
                {% endif %}
            {% else %}
                {% if currentState.config.partExpireDays | trim | length > 0 %}
                    {% if alterPartition | length > 0 %}
                        {% set alterPartition = alterPartition + ", " %}
                    {% endif %}
                    {% set alterPartition = alterPartition + 'partition_expiration_days = NULL' %}
                {% endif %}
            {% endif %}

            {% if alterPartition | trim | length > 0 %}
                {{ stage('Alter Table - Partition Options') }}
                ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                SET OPTIONS ( {{ alterPartition }} )
            {% endif %}

            {# Change table description #}
            {% if currentState.node.description != desiredState.node.description %}
                {{ stage('Alter Table - Change Table Description') }}
                ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                SET OPTIONS (description = '{{ desiredState.node.description | escape }}')
            {% endif %}

            {# Rename/Attributes Change/Drop Columns #}
            {% set ns = namespace(dropColCount=0, renameColCount=0, attributeColCount=0) %}
            {% for curCol in currentState.columns %}

                {% if curCol.id in desiredState.columns | map(attribute="id") %}
                    
                    {% set desiredColumnName = desiredState.columns | selectattr('id', 'equalto', curCol.id) | map(attribute='name') | first %}
                    {% set desiredDatatype = desiredState.columns | selectattr('id', "equalto", curCol.id) | map(attribute='dataType') | first %}
                    {% set desiredNullable = desiredState.columns | selectattr('id', "equalto", curCol.id) | map(attribute='nullable') | first %}
                    {% set desiredDefaultValue = desiredState.columns | selectattr('id', "equalto", curCol.id) | map(attribute='defaultValue') | first %}
                    {% set desiredDescription = desiredState.columns | selectattr('id', "equalto", curCol.id) | map(attribute='description') | first %}

                    {# Rename Column #}
                    {% if curCol.name != desiredColumnName %}
                        {% set ns.renameColCount = ns.renameColCount + 1 %}
                        {% if ns.renameColCount == 1 %}
                            {{ stage('Alter Table - Rename Column/s') }}
                            ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                        {% else %}
                            , 
                        {% endif %}
                        RENAME COLUMN {{ curCol.name }} TO {{ desiredColumnName }}
                    {% endif %}

                    {# Column Attribute Changes #}
                    {% set datatypeTest = curCol.dataType == desiredDatatype %}
                    {% set nullableTest = curCol.nullable == desiredNullable %}
                    {% set defaultValueTest = curCol.defaultValue == desiredDefaultValue %}
                    {% set descriptionTest = curCol.description == desiredDescription %}

                    {% if datatypeTest == false 
                        or nullableTest == false
                        or defaultValueTest == false
                        or descriptionTest == false %}

                        {% set ns.attributeColCount = ns.attributeColCount + 1 %}

                        {% if ns.attributeColCount == 1 %}
                            {{ stage('Alter Table - Change Column Attributes') }}
                            ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                        {% endif %}

                        {% if datatypeTest == false %}
                            {% if ns.attributeColCount > 1 %} , {% endif %}
                            ALTER COLUMN `{{ desiredColumnName }}`
                            SET DATA TYPE {{ desiredDatatype }}
                        {% endif %}

                        {% if nullableTest == false %}
                            {% if ns.attributeColCount > 1 %} , {% endif %}
                            {% if desiredNullable == false %}
                                ALTER COLUMN `{{ desiredColumnName }}`
                                DROP NOT NULL
                            {% else %}
                                {# Not possible for GBQ as of now #}
                            {% endif %}
                        {% endif %}

                        {% if descriptionTest == false %}
                            {% if ns.attributeColCount > 1 %} , {% endif %}
                            ALTER COLUMN `{{ desiredColumnName }}`
                            SET OPTIONS (description = '{{ desiredDescription | escape }}')
                        {% endif %}

                        {% if defaultValueTest == false %}
                            {% if ns.attributeColCount > 1 %} , {% endif %}
                            ALTER COLUMN `{{ desiredColumnName }}`
                            {% if desiredDefaultValue == '' %}
                                DROP DEFAULT
                            {% else %}
                                SET DEFAULT {{ desiredDefaultValue }}
                            {% endif %}
                        {% endif %}
        
                    {% endif %}
                {% endif %}

                {# Drop Column #}
                {% if curCol.id not in desiredState.columns | map(attribute="id") %}
                    {% set ns.dropColCount = ns.dropColCount + 1 %}
                    {% if ns.dropColCount == 1 %}
                        {{ stage('Alter Table - Drop Column/s') }}
                        ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                    {% else %}
                        , 
                    {% endif %}
                    DROP COLUMN {{ curCol.name }}
                {% endif %}
            {% endfor %}

            {# Add Columns #}
            {% set ns = namespace(addCount=0) %}
            {% for addDesCol in desiredState.columns %}
                {% if addDesCol.id not in currentState.columns | map(attribute="id") %}

                    {% set ns.addCount = ns.addCount + 1 %}
                    {% if ns.addCount == 1 %}
                        {{ stage('Alter Table - Add Columns') }}
                        ALTER TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
                    {% else %}
                        ,
                    {% endif %}
                        ADD COLUMN `{{ addDesCol.name }}` {{ addDesCol.dataType }}
                        {%- if addDesCol.defaultValue | length > 0 %} DEFAULT {{ addDesCol.defaultValue }} {%endif%}
                        {% if not addDesCol.nullable %} NOT NULL {% endif%}
                        {%- if addDesCol.description | length > 0 %} OPTIONS(description="{{ addDesCol.description | escape }}")
                    {% endif %}

                {% endif %}
            {% endfor %}

            {# Metadata Changes - Join #}
            {% set nsMetaVariables = namespace(joinTest = true) %}
            {% set nsMetaVariables.joinTest = currentState.sources | count == desiredState.sources | count %}
            {% if nsMetaVariables.joinTest %}
                {% for src in desiredState.sources %}
                    {% set matchingSource = currentState.sources | selectattr('name', 'equalto', src.name) | first %}
                    {% if matchingSource %}

                        {# Join comparison #}
                        {% set desiredStateSources = src.join | replace("{{", '"{{"') | replace("}}", '"}}"') | replace('/*', '/ *') | replace('*/', '* /') %}
                        {% set currentStateSources = matchingSource.join | replace("{{", '"{{"') | replace("}}", '"}}"') | replace('/*', '/ *') | replace('*/', '* /') %}

                        {% set nsMetaVariables.joinTest = desiredStateSources == currentStateSources %}
                        {% if nsMetaVariables.joinTest == false %}
                            {{ stage('Metadata Updates - Join') }}
                            /* "is": {{ desiredStateSources }} , "was": {{ currentStateSources }} */
                            select 1=0
                        {% endif %}

                    {% endif %}
                {% endfor %}
            {% else %}
                {# Source count mismatch — compare source names instead #}
                {% set desiredStateSources = desiredState.sources | map(attribute='name') | list | sort %}
                {% set currentStateSources = currentState.sources | map(attribute='name') | list | sort %}

                {% set nsMetaVariables.joinTest = desiredStateSources == currentStateSources %}

                {% if nsMetaVariables.joinTest == false %}
                    {{ stage('Metadta Updates - Join') }}
                    /* "is": {{ desiredStateSources }} , "was": {{ currentStateSources }} */
                    select 1=0
                {% endif %}
            {% endif %}

        {# Create table incase of current state undefined or unsupported alter changes in existing table #}
        {% elif currentState == undefined or nsCreateVariables.createTable %}

            {% if currentState != undefined and currentState.node.materializationType != desiredState.node.materializationType %}
                {{ stage('Drop Current View - ' + currentState.node.name) }}
                DROP {{currentState.node.materializationType}} IF EXISTS {{ ref_no_link(currentState.node.location.name, currentState.node.name) }}

            {% endif %}

            {# Build table options #}
            {% if node.description | length > 0 %}
                {% set nsCreateVariables.options = nsCreateVariables.options + "description = '" + node.description | escape + "'" %}
            {% endif %}

            {% if nsCreateVariables.tabEprnClause | length > 0 %}
                {% if nsCreateVariables.options | length > 0 %}
                    {% set nsCreateVariables.options = nsCreateVariables.options + ", " %}
                {% endif %}
                {% set nsCreateVariables.options = nsCreateVariables.options + "expiration_timestamp=" + nsCreateVariables.tabEprnClause %}
            {% endif %}

            {% if config.partitionFilter %}
                {% if nsCreateVariables.options | length > 0 %}
                    {% set nsCreateVariables.options = nsCreateVariables.options + ", " %}
                {% endif %}
                {% set nsCreateVariables.options = nsCreateVariables.options + "require_partition_filter=true" %}
            {% endif %}

            {% if config.partExpireDays | length > 0 %}
                {% if nsCreateVariables.options | length > 0 %}
                    {% set nsCreateVariables.options = nsCreateVariables.options + ", " %}
                {% endif %}
                {% set nsCreateVariables.options = nsCreateVariables.options + "partition_expiration_days=" + config.partExpireDays %}
            {% endif %}

            {{ stage('Create Dimension Table - ' + desiredState.node.name ) }}
            CREATE OR REPLACE TABLE {{ ref_no_link(desiredState.node.location.name, desiredState.node.name) }}
            (
                {% for col in columns %}
                    `{{ col.name }}` {{ col.dataType }}
                    {% if col.isSurrogateKey %}
                        DEFAULT GENERATE_UUID()
                    {% endif %}
                    {%- if col.defaultValue | length > 0 %} DEFAULT {{ col.defaultValue }} {%endif%}
                    {% if not col.nullable %} NOT NULL {% endif%}
                    {%- if col.description | length > 0 %} OPTIONS(description="{{ col.description | escape }}") {% endif %}
                    {%- if not loop.last -%}, {% endif %}
                {% endfor %}

                {% if nsCreateVariables.primaryKey | length > 0 %} 
                    , PRIMARY KEY ( {{ nsCreateVariables.primaryKey}} ) NOT ENFORCED
                {% endif %}
            )
                {% if nsCreateVariables.partionBy | length > 0 %}
                    PARTITION BY {{ nsCreateVariables.partionBy }}
                {% endif %}
                {% if nsCreateVariables.clusterBy | length > 0 %}
                    CLUSTER BY  {{ nsCreateVariables.clusterBy }} 
                {% endif %}
                {% if nsCreateVariables.options | trim != "" %}
                    OPTIONS ( {{ nsCreateVariables.options }} )
                {% endif %}
            
        {% endif %}
    {% endif %}

{% elif currentState != undefined and desiredState == undefined %}

    {% set fullyQualifiedTargetObjectName = ref_no_link(currentState.node.location.name, currentState.node.name) %}

    {{ stage('Drop Current ' + currentState.node.materializationType + ' - ' + currentState.node.name ) }}
    DROP {{ currentState.node.materializationType }} IF EXISTS {{ fullyQualifiedTargetObjectName }}

{% endif %}